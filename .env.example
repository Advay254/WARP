# ─────────────────────────────────────────────────────────────────────────────
# Evolution API Gateway — Environment Variables
# HuggingFace Spaces → Settings → Variables and Secrets
# ─────────────────────────────────────────────────────────────────────────────

# ── Security (ALL required for public deployment) ─────────────────────────────
EVOLUTION_API_KEY=your-strong-evolution-key        # master API key
ADMIN_KEY=your-strong-admin-key                    # extra key for create/delete
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=your-strong-dashboard-password
JWT_SECRET=run-openssl-rand-hex-32
WEBHOOK_SECRET=run-openssl-rand-hex-32             # signs outbound webhook payloads
SESSION_SECRET=run-openssl-rand-hex-32             # encrypts WhatsApp session state

# ── Server ────────────────────────────────────────────────────────────────────
# Your public HF Space URL — used for webhook registration
SERVER_URL=https://YOUR-USERNAME-evolution-api.hf.space

# ── Database (Supabase recommended) ──────────────────────────────────────────
DATABASE_ENABLED=true
DATABASE_PROVIDER=postgresql
# Use Supabase Transaction Pooler (port 6543) not direct connection (5432)
DATABASE_CONNECTION_URI=postgresql://postgres.YOURREF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?schema=public&pgbouncer=true&connection_limit=1

# ── Redis (Upstash recommended — free tier) ───────────────────────────────────
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://default:PASSWORD@REGION.upstash.io:6379

# ── Anti-ban / Rate limiting ──────────────────────────────────────────────────
# Enable for new numbers (first 7 days) — halves all rate limits, doubles delays
WARMUP_MODE=false

# Max messages per minute per instance
MSG_MAX_PER_MIN=20

# Burst limit — triggers cooldown if exceeded within 60s
MSG_BURST_LIMIT=10

# Cooldown duration in seconds after burst
MSG_BURST_COOLDOWN_SEC=300

# Min/max delay between outbound messages (milliseconds)
MSG_MIN_DELAY_MS=1500
MSG_MAX_DELAY_MS=4000

# Max bot conversation turns before handoff message
MAX_TURNS=20

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
